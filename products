<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1, user-scalable=no" />
<title>熱銷產品 - 可莉兒 Hair Salon</title>
<style>
  /* --- 基礎設定 --- */
  body { font-family: Arial, sans-serif; background: #f9fff9; color: #333; margin: 0; padding: 0; }
  
  /* --- 修正後的導航列 (同步後台風格與滑動) --- */
    /* --- 統一導航列樣式 (完全對齊 About 頁面) --- */
  /* --- 徹底對齊 About 頁面的導航列寬度與間距 --- */
  header { 
    position: fixed; 
    top: 0; 
    left: 0; 
    width: 100%; 
    background-color: #a8e6cf; 
    padding: 20px;            /* 完全同步 About 的 20px */
    z-index: 1000; 
    box-sizing: border-box;
    display: block;           /* 移除 flex，改回塊狀，寬度就不會被強行撐開 */
    text-align: left;         /* 確保內容靠左 */
  }

  header h2 { 
    margin: 0; 
    color: #4a7c53; 
    font-size: 24px;          /* 確保與 About 字體大小一致 */
    font-weight: bold; 
    display: block;
  }

  nav {
    width: 100%;
    margin: 0;                /* 移除額外邊距 */
  }

  nav ul { 
    list-style: none; 
    display: flex; 
    gap: 15px; 
    padding: 10px 0 0;        /* 完全同步 About 的 padding-top: 10px */
    margin: 0; 
    overflow-x: auto; 
    white-space: nowrap; 
    -webkit-overflow-scrolling: touch; 
  }

  /* 隱藏捲軸（美化用） */
  nav ul::-webkit-scrollbar { display: none; }

  nav li { 
    flex: 0 0 auto;           /* 確保項目寬度一致 */
  }

  nav a { 
    text-decoration: none; 
    color: #333; 
    font-weight: bold; 
    padding: 6px 10px;        /* 完全同步 About 的 padding */
    border-radius: 4px; 
    display: inline-block;
    font-size: 16px;
  }
  
  nav a:hover, nav a.active { 
    background-color: #7bd8a2; 
    color: white; 
  }

  /* --- 內容間距修正 (防止被 Header 遮住) --- */
  main { 
    max-width: 900px;         /* 同步 About 的 900px */
    margin: 140px auto 40px;  /* 根據新高度調整上方間距 */
    padding: 0 20px; 
  }
  h1 { color: #4a7c53; text-align: center; margin-bottom: 30px; }

  .product-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 25px;
  }
  .product-card {
    background: white; border-radius: 10px; overflow: hidden;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    transition: transform 0.2s; display: flex; flex-direction: column;
  }
  .product-card:hover { transform: translateY(-5px); }
  .product-img { width: 100%; height: 250px; object-fit: cover; background: #eee; }
  .product-info { padding: 20px; flex-grow: 1; display: flex; flex-direction: column; }
  .product-title { font-size: 1.2rem; font-weight: bold; color: #4a7c53; margin-bottom: 10px; }
  .product-desc { font-size: 0.9rem; color: #666; margin-bottom: 15px; line-height: 1.5; flex-grow: 1; white-space: pre-wrap; }
  .product-price { font-size: 1.1rem; font-weight: bold; color: #e74c3c; margin-bottom: 15px; }
  .buy-btn {
    background-color: #4a7c53; color: white; border: none; padding: 12px; width: 100%;
    border-radius: 5px; cursor: pointer; font-size: 1rem; text-align: center; text-decoration: none; display: block;
    box-sizing: border-box;
  }
  .buy-btn:hover { background-color: #3d6645; }
  
  #loading { text-align: center; font-size: 1.2rem; color: #666; margin-top: 50px; }
</style>
</head>
<body>

<header>
  <h2>可莉兒 Hair Salon</h2>
  <nav>
    <ul>
      <li><a href="index.html">首頁</a></li>
      <li><a href="about.html">關於我們</a></li>
      <li><a href="services.html">服務項目</a></li>
      <li><a href="pricing.html">價目表</a></li>
      <li><a href="booking.html">預約</a></li>
      <li><a href="news.html">最新消息</a></li>
      <li><a href="products.html" class="active">熱銷產品</a></li>
      <li><a href="contact.html">聯絡我們</a></li>
    </ul>
  </nav>
</header>

<main>
  <h1>店內嚴選好物</h1>
  <p style="text-align: center; margin-bottom: 30px; color: #666;">
    在家也能享受沙龍級護理。歡迎點擊按鈕直接 LINE 我們預留喔！
  </p>

  <div id="loading">正在載入最新產品...</div>
  <div class="product-grid" id="productContainer"></div>
</main>

<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
<script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-firestore-compat.js"></script>

<script>
  const firebaseConfig = {
    apiKey: "AIzaSyCfxDOOzTLbmQRfvW275hJrtOnX_t-6-yc",
    authDomain: "hsinformation.firebaseapp.com",
    projectId: "hsinformation",
  };
  
  if (!firebase.apps.length) {
    firebase.initializeApp(firebaseConfig);
  }
  const db = firebase.firestore();

  const container = document.getElementById('productContainer');
  const loading = document.getElementById('loading');

  // 讀取產品資料
  db.collection('products').orderBy('createdAt', 'desc').get().then((querySnapshot) => {
    loading.style.display = 'none';
    
    if (querySnapshot.empty) {
      container.innerHTML = '<p style="text-align:center; width:100%;">目前沒有上架的產品。</p>';
      return;
    }

    querySnapshot.forEach((doc) => {
      const p = doc.data();
      const html = `
        <div class="product-card">
          <img src="${p.imageUrl}" alt="${p.name}" class="product-img">
          <div class="product-info">
            <div class="product-title">${p.name}</div>
            <div class="product-desc">${p.description}</div>
            <div class="product-price">NT$ ${p.price}</div>
            <a href="javascript:void(0)" onclick="orderProduct('${p.name}')" class="buy-btn">
               LINE 詢問 / 購買
            </a>
          </div>
        </div>
      `;
      container.innerHTML += html;
    });
  }).catch((error) => {
    loading.innerText = "載入失敗，請檢查網路連線";
  });

  function orderProduct(productName) {
    var lineBaseUrl = "https://line.me/R/oaMessage/@491xwhjb/?";
    var message = "你好，我在網站上看到【" + productName + "】，我想購買或詢問詳情，請問店裡有現貨嗎？";
    window.open(lineBaseUrl + encodeURIComponent(message));
  }
</script>

</body>
</html>
